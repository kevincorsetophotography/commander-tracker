# Database PostgreSQL (in produzione lo fornisce Railway come variabile DATABASE_URL)
# Esempio: postgresql://user:password@host:5432/dbname
DATABASE_URL="postgresql://user:password@localhost:5432/commanderone"

# Segreto per firmare i JWT — stringa casuale di almeno 32 caratteri.
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-with-a-long-random-string"

# Porta del server (Railway la imposta da solo; in locale 3001)
PORT=3001

# Origine consentita per CORS — URL del frontend (su Vercel in produzione)
FRONTEND_URL="http://localhost:5173"

# Codice d'invito richiesto per la registrazione self-service.
INVITE_CODE="commanderone-villastellone"

# Admin creato/aggiornato automaticamente all'avvio in produzione (start:prod)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambia-questa-password"
