{
  "name": "commander-tracker-backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:prod": "prisma db push --skip-generate --accept-data-loss && node src/ensureAdmin.js && node src/migrateNotificationLinks.js && node src/index.js",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "admin:ensure": "node src/ensureAdmin.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.0.0"
  },
  "devDependencies": {
    "embedded-postgres": "^18.3.0-beta.17",
    "nodemon": "^3.0.0",
    "vitest": "^2.1.9"
  }
}
