generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  username    String       @unique
  password    String       // bcrypt hash
  role        String       @default("PLAYER")
  createdAt   DateTime     @default(now())
  decks       Deck[]
  gamePlayers GamePlayer[]
  createdGames Game[]      @relation("GameCreator")
  comments    Comment[]
  reactions   Reaction[]
  createdEvents Event[]    @relation("EventCreator")
  eventRsvps  EventRsvp[]
}

model Deck {
  id          Int          @id @default(autoincrement())
  name        String
  commander   String?
  colors      String?      // es. "WUBRG"
  decklist    String?
  bracket     Int?         // 1=Casual, 2=Bilanciato, 3=Potente, 4=cEDH
  archetype   String?      // es. Aggro, Control, Combo, Midrange, Stax...
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id])
  userId      Int
  gamePlayers GamePlayer[]

  @@unique([userId, name])
}

model Game {
  id              Int          @id @default(autoincrement())
  playedAt        DateTime     @default(now())
  notes           String?
  createdByUserId Int?
  createdBy       User?        @relation("GameCreator", fields: [createdByUserId], references: [id])
  players         GamePlayer[]
  comments        Comment[]
  reactions       Reaction[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int

  @@index([gameId])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  emoji     String
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int

  @@unique([gameId, userId, emoji])
  @@index([gameId])
}

model Event {
  id              Int         @id @default(autoincrement())
  title           String
  description     String?
  startsAt        DateTime
  allDay          Boolean     @default(false)
  location        String?
  createdAt       DateTime    @default(now())
  createdBy       User?       @relation("EventCreator", fields: [createdByUserId], references: [id])
  createdByUserId Int?
  rsvps           EventRsvp[]

  @@index([startsAt])
}

model EventRsvp {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int

  @@unique([eventId, userId])
  @@index([eventId])
}

model GamePlayer {
  id             Int     @id @default(autoincrement())
  isWinner       Boolean @default(false)
  placement      Int?    // 1 = vincitore (ultimo in piedi), N = primo eliminato
  eliminatedById Int?    // userId di chi ha eliminato questo giocatore (null = sconosciuto)
  game           Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId   Int
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
  deck     Deck    @relation(fields: [deckId], references: [id])
  deckId   Int
}
